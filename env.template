# =============================================================================
# .env  — ServiceNow → Jira Integration  (SPN AAD + Azure Key Vault)
# =============================================================================
# COMMIT:  .env.template   (this file without real values)
# IGNORE:  .env            (add to .gitignore — never commit)
#
# RULE:
#   Values marked [KEY VAULT] must NEVER be stored here.
#   KV_SECRET_* entries are just the secret NAMES (lookup keys) — safe to store.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# SPN AAD CREDENTIALS  — used to LOGIN to Azure Key Vault
# These allow the app to authenticate as a Service Principal and fetch secrets.
# ─────────────────────────────────────────────────────────────────────────────
AZURE_TENANT_ID             = xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID             = xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET         = <your-spn-client-secret>
#                              ↑ [KEY VAULT alternative for production]
#                                Ideally store this in Key Vault or CI/CD secrets too.
#                                For local dev, keeping it in .env is acceptable.


# ─────────────────────────────────────────────────────────────────────────────
# AZURE KEY VAULT
# ─────────────────────────────────────────────────────────────────────────────
AZURE_KEYVAULT_URL          = https://your-vault-name.vault.azure.net/

# Names of secrets inside Key Vault — just pointers, NOT the actual values
KV_SECRET_SNOW_PASS         = snow-api-password
KV_SECRET_JIRA_TOKEN        = jira-api-token
KV_SECRET_WEBHOOK_SECRET    = webhook-hmac-secret


# ─────────────────────────────────────────────────────────────────────────────
# SERVICENOW — Non-sensitive config only
# [KEY VAULT] SNOW_PASS → fetched from 'snow-api-password' secret
# ─────────────────────────────────────────────────────────────────────────────
SNOW_INSTANCE               = your-instance.service-now.com
SNOW_USER                   = servicenow_api_user
SNOW_TABLE                  = sc_request
SNOW_LIMIT                  = 50


# ─────────────────────────────────────────────────────────────────────────────
# JIRA — Non-sensitive config only
# [KEY VAULT] JIRA_API_TOKEN → fetched from 'jira-api-token' secret
# ─────────────────────────────────────────────────────────────────────────────
JIRA_BASE_URL               = https://your-org.atlassian.net
JIRA_USER                   = jira_service_account@company.com
JIRA_PROJECT_KEY            = PROJ
JIRA_TYPE                   = cloud


# ─────────────────────────────────────────────────────────────────────────────
# TEAM FILTERS — batch script (snow_jira_creator.py)
# ─────────────────────────────────────────────────────────────────────────────
TEAM_ASSIGNMENT_GROUP       = Cloud Platform Engineering
TEAM_MEMBERS                = alice@company.com,bob@company.com,sunita@company.com
TEAM_CATEGORIES             = AI Platform,Data Engineering,Cloud
TEAM_CIS                    = SafeAlign,AI-Gateway,OpenShift-Cluster
TEAM_FILTER_STRATEGY        = group


# ─────────────────────────────────────────────────────────────────────────────
# WEBHOOK SETTINGS — webhook listener (snow_jira_webhook.py)
# [KEY VAULT] WEBHOOK_SECRET → fetched from 'webhook-hmac-secret' secret
# ─────────────────────────────────────────────────────────────────────────────
TEAM_ASSIGNMENT_GROUPS      = Cloud Platform Engineering,AI Platform Team
SNOW_WRITEBACK              = true
PORT                        = 8080
